{
  "name": "trackeros",
  "version": "0.1.0",
  "tier": "tier1",
  "templateId": "corporate-ops-web-mobile",
  "description": "Web application to help user to track his tasks",
  "stack": {
    "language": "typescript",
    "runtime": "node20",
    "packageManager": "pnpm",
    "frontend": "react",
    "backend": "node-fastify",
    "database": "postgres",
    "architectureStyle": "modular-monolith"
  },
  "adapters": {
    "database": {
      "type": "postgres",
      "configKey": "DATABASE_URL"
    },
    "queue": {
      "type": "bullmq",
      "configKey": "REDIS_URL"
    },
    "llm": {
      "type": "azure-openai",
      "configKey": "LLM_BASE_URL"
    }
  },
  "qualityGate": {
    "required": [
      "lint",
      "typecheck",
      "unit-tests",
      "constraint-check",
      "security-scan"
    ],
    "blockingSignals": [
      "GOLDEN_PRINCIPLE_BREACH",
      "CONSTRAINT_VIOLATION"
    ],
    "autoResolvableSignals": [
      "LINT_FAILURE",
      "TEST_FAILURE"
    ],
    "maxRetries": 3
  },
  "constraints": {
    "rules": [
      {
        "id": "no-any",
        "description": "Use unknown with type guards instead of any",
        "severity": "high"
      },
      {
        "id": "no-direct-db-outside-repository",
        "description": "Database calls must go through repository pattern",
        "severity": "critical"
      },
      {
        "id": "no-hardcoded-secrets",
        "description": "No hardcoded passwords, API keys, or tokens",
        "severity": "critical"
      },
      {
        "id": "no-gestalt-internal-deps",
        "description": "Do not add @gestalt/* packages as project dependencies — these are Gestalt platform internals not available on npm",
        "severity": "critical"
      }
    ]
  },
  "pipeline": {
    "adapter": "github-actions",
    "autoMerge": true,
    "mergeMethod": "squash"
  },
  "maintenance": {
    "driftCheck": {
      "enabled": true,
      "scheduleUtc": "0 2 * * *"
    },
    "alignmentCheck": {
      "enabled": true,
      "scheduleUtc": "0 3 * * *"
    },
    "gcCheck": {
      "enabled": true,
      "scheduleUtc": "0 4 * * 5"
    },
    "monitoring": {
      "adapter": "noop",
      "enabled": true,
      "connectionConfig": {},
      "thresholds": {
        "errorRatePercent": 5,
        "latencyP99Ms": 2000,
        "alertCountWindow": "1h",
        "alertCountThreshold": 10
      }
    }
  },
  "identity": {
    "providers": [
      {
        "type": "local",
        "enabled": true,
        "warningBanner": true,
        "allowedInProduction": false
      }
    ],
    "roleMapping": [],
    "defaultRole": null,
    "sessionTtlMinutes": 480
  }
}
