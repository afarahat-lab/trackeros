{
  "name": "trackeros",
  "version": "0.1.0",
  "tier": "tier1",
  "templateId": "corporate-ops-web-mobile",
  "description": "A simle web application that helps user to capture his notes. It shall run server on a docker image",
  "stack": {
    "language": "typescript",
    "runtime": "node20",
    "packageManager": "pnpm",
    "frontend": "react",
    "backend": "node-fastify",
    "database": "postgres",
    "architectureStyle": "modular-monolith"
  },
  "adapters": {
    "database": {
      "type": "postgres",
      "configKey": "DATABASE_URL"
    },
    "queue": {
      "type": "bullmq",
      "configKey": "REDIS_URL"
    },
    "llm": {
      "type": "azure-openai",
      "configKey": "LLM_BASE_URL"
    }
  },
  "qualityGate": {
    "required": [
      "lint",
      "typecheck",
      "unit-tests",
      "constraint-check",
      "security-scan"
    ],
    "blockingSignals": [
      "GOLDEN_PRINCIPLE_BREACH",
      "CONSTRAINT_VIOLATION"
    ],
    "autoResolvableSignals": [
      "LINT_FAILURE",
      "TEST_FAILURE"
    ],
    "maxRetries": 3
  },
  "pipeline": {
    "adapter": "github-actions"
  },
  "maintenance": {
    "driftCheck": {
      "enabled": true,
      "scheduleUtc": "0 2 * * *"
    },
    "alignmentCheck": {
      "enabled": true,
      "scheduleUtc": "0 3 * * *"
    },
    "gcCheck": {
      "enabled": true,
      "scheduleUtc": "0 4 * * 5"
    },
    "monitoring": {
      "adapter": "noop",
      "enabled": true,
      "connectionConfig": {},
      "thresholds": {
        "errorRatePercent": 5,
        "latencyP99Ms": 2000,
        "alertCountWindow": "1h",
        "alertCountThreshold": 10
      }
    }
  },
  "identity": {
    "providers": [
      {
        "type": "local",
        "enabled": true,
        "warningBanner": true,
        "allowedInProduction": false
      }
    ],
    "roleMapping": [],
    "defaultRole": null,
    "sessionTtlMinutes": 480
  },
  "constraints": {
    "rules": [
      {
        "id": "no-direct-db-access-outside-shared-db",
        "description": "Database access must go through repositories under src/shared/db/. Route handlers, services, and modules must NOT import postgres / mysql / sqlite directly.",
        "severity": "high"
      },
      {
        "id": "no-inline-rbac-checks",
        "description": "RBAC must be enforced via middleware on the route. Do not inline `if (user.role !== ...)` checks inside handlers.",
        "severity": "high"
      },
      {
        "id": "audit-state-changes",
        "description": "Every POST/PUT/PATCH/DELETE handler must append an audit record (GP-002).",
        "severity": "critical"
      },
      {
        "id": "validate-input-with-zod",
        "description": "All request bodies must be validated with a Zod schema at the API boundary before any business logic runs (GP-003).",
        "severity": "high"
      },
      {
        "id": "no-process-env-outside-config",
        "description": "Do not read `process.env` directly. Use the config module so configuration stays validated and centralised.",
        "severity": "medium"
      },
      {
        "id": "no-console-log",
        "description": "Use the platform logger instead of `console.log` / `console.error`. Logs must be structured and respect log levels.",
        "severity": "medium"
      },
      {
        "id": "no-any-type",
        "description": "Do not use TypeScript `any`. Use `unknown` with a type guard, or define a precise interface.",
        "severity": "medium"
      },
      {
        "id": "no-hardcoded-secrets",
        "description": "Secrets, API keys, tokens must never appear as string literals. Load from environment + config module.",
        "severity": "critical"
      }
    ]
  }
}