+employee.routes.ts
+policy/
+policy.model.ts
+policy.repository.ts
+policy.service.ts
+policy.routes.ts
+balance/
+balance.model.ts
+balance.repository.ts
+balance.service.ts
+shared/
+db/
+connection.ts           ← pg Pool, single instance
+base-repository.ts      ← shared
+
